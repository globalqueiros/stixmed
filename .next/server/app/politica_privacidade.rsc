ck","width":135,"height":50}]}]]}]}]],["$","$L9",null,{"gaId":"G-BVVT8LYMPM"}]]}]]}]]}],{"children":["politica_privacidade",["$","$1","c",{"children":[null,["$","$L4",null,{"parallelRouterKey":"children","segmentPath":["children","politica_privacidade","children"],"error":"$undefined","errorStyles":"$undefined","errorScripts":"$undefined","template":["$","$L5",null,{}],"templateStyles":"$undefined","templateScripts":"$undefined","notFound":"$undefined","forbidden":"$undefined","unauthorized":"$undefined"}]]}],{"children":["__PAGE__",["$","$1","c",{"children":[[["$","div",null,{"className":"styles_title__1imVD","children":["$","div",null,{"className":"max-w-7xl mx-auto px-4 sm:px-6 lg:px-7","children":["$","h3",null,{"className":"text-2xl","children":"Política de Privacidade"}]}]}],["$","div",null,{"className":"max-w-7xl mx-auto px-4e sm:px-6 lg:px-8","children":[["$","h6",null,{"className":"text-xl font-bold mb-1","children":"Política de Privacidade de Dados da Stixmed"}],["$","p",null,{"className":"text-sm pt-1 text-justify","children":["Na Stixmed (",["$","strong",null,{"children":"Stixmed Assistência Domiciliar LTDA"}],"), a privacidade dos usuários é tratada como prioridade. Em conformidade com o artigo 6º da Lei Geral de Proteção de Dados Pessoais (LGPD), as atividades de tratamento de dados pessoais são conduzidas com base na boa-fé, respeitando princípios essenciais como transparência, segurança e responsabilidade."]}],["$","p",null,{"className":"text-sm pt-2 text-justify","children":"Esta Política de Privacidade detalha os procedimentos adotados para a coleta, utilização, divulgação, transferência e armazenamento das informações dos usuários. Ao acessar nossa plataforma, efetuar seu registro (por meio da plataforma, Whatsapp, atendimento presencial em nossa unidade) ou participar de atividades realizadas em ações promocionais de rua ou clínicas parceiras, o usuário declara sua concordância com os Termos de Uso e a Política de Privacidade apresentados neste documento."}],["$","p",null,{"className":"text-base py-2 text-justify","children":["$","strong",null,{"children":"RECOMENDAMOS A LEITURA ATENTA DA POLÍTICA ABAIXO, QUE DESCREVE COMO SEUS DADOS PESSOAIS SÃO TRATADOS QUANDO VOCÊ: (I) UTILIZA OU REALIZA ALGUM SERVIÇO DA STIXMED; (II) ACESSA NOSSA PLATAFORMA; E (III) ENTRA EM CONTATO CONOSCO POR MEIO DE NOSSOS CANAIS DE ATENDIMENTO."}]}],["$","p",null,{"className":"text-sm text-justify","children":"Ao aceitar este termo, o titular concorda e consente que a STIXMED, daqui em diante designada como Controladora, tome decisões relacionadas ao tratamento de seus dados pessoais, bem como realize o tratamento desses dados por meio de operações como coleta, produção, classificação, utilização, acesso, reprodução, transmissão, distribuição, processamento, arquivamento, armazenamento, eliminação, avaliação, controle da informação, modificação, comunicação, transferência, difusão ou extração."}],["$","p",null,{"className":"text-lg font-bold mt-3 mb-2","children":"QUADRO DE RESUMO"}],["$","p",null,{"className":"text-sm pb-3 text-justify","children":"O quadro resumo abaixo tem como objetivo ilustrar de forma mais clara como será realizado o tratamento dos dados, conforme especificado neste documento:"}],["$","table",null,{"className":"table-responsive table table-bordered","children":[["$","thead",null,{"children":["$","tr",null,{"children":[["$","th",null,{"scope":"col","children":["$","p",null,{"className":"text-sm pt-0","children":"Agente de tratamento"}]}],["$","td",null,{"children":["$","p",null,{"className":"text-sm","children":["Stixmed Assistencia Domiciliar LTDA",["$","br",null,{}],"CNPJ: 57.122.877/0001-72",["$","br",null,{}],"Endereço: Rua: Cel Jose Eusebio, Nº 95 - Casa 13, Bairro: Higienópolis, São Paulo - SP"]}]}]]}]}],["$","tbody",null,{"children":[["$","tr",null,{"children":[["$","th",null,{"scope":"col","children":["$","p",null,{"className":"text-sm pt-0","children":"Titular dos dados"}]}],["$","td",null,{"children":["$","p",null,{"className":"text-sm","children":["$","strong",null,{"children":"Indivíduos que realizarem seu cadastro e fornecerem informações nos canais de contato da STIXMED, abrangendo, mas não se restringindo, à plataforma online ou ao atendimento via whatsapp da STIXMED."}]}]}]]}],["$","tr",null,{"children":[["$","th",null,{"scope":"col","children":["$","p",null,{"className":"text-sm pt-0","children":"Papel no tratamento"}]}],["$","td",null,{"children":["$","p",null,{"className":"text-sm","children":"Predominantemente controladora."}]}]]}],["$","tr",null,{"children":[["$","th",null,{"scope":"col","children":["$","p",null,{"className":"text-sm pt-0","children":"Objetivo da coleta"}]}],["$","td",null,{"children":["$","p",null,{"className":"text-sm","children":"Registro destinado à utilização dos serviços disponibilizados pela STIXMED e seus parceiros comerciais."}]}]]}],["$","tr",null,{"children":[["$","th",null,{"scope":"col","children":["$","p",null,{"className":"text-sm pt-0","children":"Natureza dos dados tratados"}]}],["$","td",null,{"children":["$","p",null,{"className":"text-sm","children":"Informações pessoais fornecidas pelo usuário e/ou obtidas de forma automatizada."}]}]]}],["$","tr",null,{"children":[["$","th",null,{"scope":"col","children":["$","p",null,{"className":"text-sm pt-0","children":"Finalidade como Controladora"}]}],["$","td",null,{"children":["$","p",null,{"className":"text-sm","children":["Realizar o tratamento de dados pessoais dos usuários para finalidades publicitárias, envio de cupons de desconto, informativos, e comunicações relacionadas à consulta, incluindo promoções próprias e de parceiros, além da identificação do paciente durante atendimentos.",["$","br",null,{}],["$","strong",null,{"children":"Base legal:"}]," consentimento do titular e atividades vinculadas ao cuidado em saúde."]}]}]]}],["$","tr",null,{"children":[["$","th",null,{"scope":"col","children":["$","p",null,{"className":"text-sm pt-0","children":"Compartilhamento"}]}],["$","td",null,{"children":["$","p",null,{"className":"text-sm","children":"Outros agentes de tratamento de dados, sempre que necessário para as finalidades específicas mencionadas acima, desde que sejam indispensáveis à execução dos serviços oferecidos pela plataforma. O principal desses agentes é o médico responsável pelo atendimento. Todos os prestadores de serviços envolvidos estão sujeitos a esta Política de Privacidade e à legislação de proteção de dados pessoais, em especial à Lei nº 13.709/2018."}]}]]}],["$","tr",null,{"children":[["$","th",null,{"scope":"col","children":["$","p",null,{"className":"text-sm pt-0","children":"Proteção de dados"}]}],["$","td",null,{"children":["$","p",null,{"className":"text-sm","children":"Adoção de medidas de segurança técnicas e administrativas apropriadas."}]}]]}],["$","tr",null,{"children":[["$","th",null,{"scope":"col","children":["$","p",null,{"className":"text-sm pt-0","children":"Direiros do titular"}]}],["$","td",null,{"children":["$","p",null,{"className":"text-sm","children":"Solicitação de confirmação sobre a existência do tratamento, acesso aos dados pessoais, retificação, exclusão, portabilidade, entre outros direitos."}]}]]}],["$","tr",null,{"children":[["$","th",null,{"scope":"col","children":["$","p",null,{"className":"text-sm pt-0","children":"Contato"}]}],["$","td",null,{"children":["$","p",null,{"className":"text-sm","children":["Email: ",["$","a",null,{"style":{"color":"black","fontSize":"14px"},"href":"malito:privacidade@stixmed.med.br","children":"privacidade@stixmed.med.br"}]]}]}]]}]]}]]}],["$","h6",null,{"className":"text-lg pb-2 pt-2","style":{"fontWeight":"600"},"children":"1. Cadastro no agendamento online (agenda@stixmed.med.br), whatsapp ou telefone"}],["$","p",null,{"className":"text-sm text-justify","children":"É permitido que cada paciente realize apenas um cadastro junto à Stixmed. Ao efetuar o cadastro, a Stixmed armazena os dados fornecidos em seu banco de dados, sendo de total responsabilidade de quem realiza o cadastro a veracidade das informações fornecidas."}],["$","h6",null,{"className":"text-lg pb-2 pt-4","style":{"fontWeight":"600"},"children":"2. Coleta de Dados Pessoais"}],["$","p",null,{"className":"text-sm","children":"Ao registrar um prontuário em nosso site, realizar uma consulta ou agendamento na plataforma da Stixmed, ou ao efetuar um agendamento de consulta médica por meio do whatsapp ou telefone, poderemos coletar informações pessoais suas, incluindo, mas não se limitando, ao seu nome, endereço, CPF (ou outro número de documento), gênero, data de nascimento, celular e email. Esses dados pessoais também poderão ser coletados por meio dos formulários da plataforma do paciente da Stixmed."}],["$","p",null,{"className":"text-sm pt-2","children":"Os dados pessoais fornecidos pelo paciente podem ser solicitados a qualquer momento pelo próprio paciente durante o período de validade do cadastro junto à Stixmed, seja por meio do site, aplicativo ou telefone. Os dados de prontuários médicos são armazenados em nossos servidores, contendo o histórico do paciente referente a consultas e exames realizados, os quais compõem o prontuário médico. Esses dados estão sujeitos ao sigilo profissional, conforme exigido pelas normas do CFM, CFO e demais Conselhos Representativos dos profissionais de saúde, podendo ser acessados exclusivamente pelo próprio paciente ou mediante ordem judicial."}],["$","p",null,{"className":"text-sm pt-2","children":"Caso você seja menor de idade, seus dados serão tratados com a mesma proteção e sigilo, e garantiremos o seu atendimento médico conforme os termos estabelecidos pela Lei nº 13.989/2020, bem como pelo Estatuto da Criança e do Adolescente."}],["$","p",null,{"className":"text-sm pt-2","children":"Os dados coletados também poderão ser associados a outros dados com o objetivo de aprimorar nossos produtos, serviços e campanhas publicitárias, conforme estabelecido nesta Política de Dados."}],["$","h6",null,{"className":"text-lg pb-2 pt-4","style":{"fontWeight":"600"},"children":"3. Como os dados são utilizados"}],["$","p",null,{"className":"text-sm","children":"Os dados pessoais coletados são utilizados para estabelecer comunicação com você, fornecer informações sobre novos anúncios e serviços e eventos promovidos pela Stixmed e seus parceiros comerciais. Ressaltamos que você pode, a qualquer momento, optar por não receber nossas comunicações, seja no momento do cadastro ou por meio da atualização de suas preferências de email."}],["$","p",null,{"className":"text-sm pt-2","children":"Os dados pessoais também são utilizados para aprimorar e desenvolver nossos produtos, serviços, conteúdos e estratégias de publicidade. Além disso, esses dados serão analisados para compreender seu comportamento de serviços e direcionar ações publicitárias por meio das seguintes ferramentas:"}],["$","ul",null,{"children":[["$","li",null,{"children":["$","p",null,{"className":"text-sm pt-0","children":"- Google Analytics"}]}],["$","li",null,{"children":["$","p",null,{"className":"text-sm pt-0","children":"- Pixel Facebook"}]}]]}],["$","p",null,{"className":"text-sm pt-2 text-justify","children":"Esses dados também poderão ser compartilhados com os parceiros de negócios da Stixmed. A lista completa desses parceiros pode ser consultada em: (https://stixmed.med.br/parceiros/), permitindo que eles ofereçam serviços de seu interesse em condições especiais."}],["$","p",null,{"className":"text-sm pt-2 text-justify","children":"Os dados pessoais poderão ser utilizados para o envio de informações, comunicações, e notificações sobre alterações de termos, condições e procedimentos diretamente a você."}],["$","p",null,{"className":"text-sm pt-2 text-justify","children":"Os dados pessoais poderão ser utilizados internamente para a realização de auditorias, análises de dados e pesquisas, com o objetivo de aprimorar os serviços e a comunicação com os pacientes da Stixmed."}],["$","p",null,{"className":"text-sm pt-2 text-justify","children":"Os dados pessoais poderão ser utilizados para estabelecer contato com a finalidade de confirmar consultas ou procedimentos, bem como para realizar contatos pós-consulta, incluindo, mas não se limitando, à aplicação de pesquisas de satisfação. Esses dados também poderão ser tratados para a oferta de outros serviços de interesse, alinhados ao perfil do titular. Informamos que os dados são compartilhados pela Stixmed com o objetivo de preservar o histórico de atendimentos realizados, assegurando uma experiência aprimorada tanto para você quanto para o profissional de saúde responsável pelo seu atendimento."}],["$","h6",null,{"className":"text-lg pb-2 pt-4","style":{"fontWeight":"600"},"children":"4. Coleta de dados não pessoais"}],["$","p",null,{"className":"text-sm pt-2 text-justify","children":"Também coletamos dados que, analisados de forma isolada, não permitem a associação direta a um indivíduo específico. Podemos coletar, utilizar, transferir e divulgar informações não pessoais para quaisquer finalidades. Dados não pessoais incluem, mas não se limitam a, ocupação, idioma, código postal, código de área, identificador único de dispositivo, localização e fuso horário em que serviços da Stixmed é utilizado, com o objetivo de compreender melhor o comportamento dos pacientes e aprimorar nossos serviços e campanhas publicitárias."}],["$","p",null,{"className":"text-sm pt-2 text-justify","children":"Também coletamos dados sobre as atividades dos pacientes e usuários em nossos sites ou serviços. Esses dados são utilizados com a finalidade de nos auxiliar no fornecimento de serviços mais úteis e completos aos nossos pacientes, além de nos ajudar a compreender quais partes desses serviços geram maior interesse."}],["$","p",null,{"className":"text-sm pt-2 text-justify","children":"Quando dados pessoais forem combinados com dados não pessoais, os dados resultantes dessa combinação serão tratados como dados pessoais."}],["$","h6",null,{"className":"text-lg pb-2 pt-4","style":{"fontWeight":"600"},"children":"5. Outros usos dos dados coletados"}],["$","p",null,{"className":"text-sm pt-2 text-justify","children":"Independentemente de se tratarem de dados pessoais ou não pessoais, o Stixmed poderá utilizar os dados e informações coletados para as seguintes finalidades:"}],["$","ul",null,{"className":"pt-2","style":{"listStyle":"disc"},"children":[["$","li",null,{"children":["$","p",null,{"className":"text-sm pt-0 text-justify","children":"Responder a eventuais dúvidas e solicitações do paciente;"}]}],["$","li",null,{"children":["$","p",null,{"className":"text-sm pt-0 text-justify","children":"Cumprimento de ordem legal ou judicial;"}]}],["$","li",null,{"children":["$","p",null,{"className":"text-sm pt-0 text-justify","children":"Constituir, defender ou exercer regularmente direitos em âmbito judicial ou administrativo;"}]}],["$","li",null,{"children":["$","p",null,{"className":"text-sm pt-0 text-justify","children":"Garantir a segurança dos pacientes;"}]}],["$","li",null,{"children":["$","p",null,{"className":"text-sm pt-0 text-justify","children":"Manter atualizados os cadastros dos pacientes para contato por telefone fixo, celular, e-mail, SMS, mala direta, redes sociais ou por outros meios de comunicação;"}]}],["$","li",null,{"children":["$","p",null,{"className":"text-sm pt-0 text-justify","children":"Manter atualizados os cadastros dos pacientes para contato por telefone fixo, celular, e-mail, SMS, mala direta, redes sociais ou por outros meios de comunicação;"}]}],["$","li",null,{"children":["$","p",null,{"className":"text-sm pt-0 text-justify","children":"Promover o serviço e seus parceiros, comerciais ou não, e informar sobre novas oportunidades e benefícios para o paciente;"}]}],["$","li",null,{"children":["$","p",null,{"className":"text-sm pt-0 text-justify","children":"Gerar análises e estudos, sejam estatísticos ou identificáveis, com base no comportamento de uso das ferramentas, site, produtos e serviços do Stixmed;"}]}],["$","li",null,{"children":["$","p",null,{"className":"text-sm pt-0 text-justify","children":"Promover o serviço e seus parceiros, comerciais ou não, e informar sobre novas oportunidades e benefícios para o paciente;"}]}],["$","li",null,{"children":["$","p",null,{"className":"text-sm pt-0 text-justify","children":"Aperfeiçoar o uso e a experiência interativa durante a navegação do paciente no site, produtos e serviços do Stixmed bem como das demais ferramentas e plataformas lançadas pelo Stixmed;"}]}],["$","li",null,{"children":["$","p",null,{"className":"text-sm pt-0 text-justify","children":"Os dados adquiridos somente poderão ser acessados por profissionais devidamente autorizados pelo Stixmed, respeitando a necessidade a que serão submetidos, a relevância para os objetivos do Stixmed e os interesses dos usuários, além de preservar sua privacidade;"}]}],["$","li",null,{"children":["$","p",null,{"className":"text-sm pt-0 text-justify","children":"Prover um prontuário eletrônico único em ambiente seguro disponível aos profissionais de saúde, por meio de login e arquivamento de logs de acesso, que atendem na Rede de Clínicas Stixmed."}]}]]}],["$","h6",null,{"className":"text-lg pb-2 pt-4","style":{"fontWeight":"600"},"children":"6. Cookies e outras tecnologias"}],["$","p",null,{"className":"text-sm pt-2 text-justify","children":"O site, os serviços online, os aplicativos interativos, as mensagens de email e as propagandas da Stixmed podem utilizar “cookies” e outras tecnologias, como pixel tags e web beacons."}],["$","p",null,{"className":"text-sm pt-2 text-justify","children":"Essas tecnologias auxiliam na compreensão do comportamento dos pacientes, informando quais partes do site foram visitadas, além de contribuir para a mensuração da eficácia de propagandas e pesquisas online. As informações coletadas por meio de cookies e outras tecnologias são tratadas como informações não pessoais. Entretanto, caso endereços de Protocolo da Internet (IP, Internet Protocol) ou identificadores semelhantes sejam considerados informações pessoais pela legislação local, tais identificadores serão tratados como informações pessoais. Da mesma forma, quando informações não pessoais são combinadas com informações pessoais, as informações combinadas serão tratadas como dados pessoais, conforme definido nesta Política de Privacidade."}],["$","p",null,{"className":"text-sm pt-2 text-justify","children":"A Stixmed e seus parceiros utilizam cookies e tecnologias para personalizar anúncios, medir desempenho de campanhas e analisar comportamentos de pacientes. Esses dados também são usados em estratégias de marketing. Tags de pixel permitem monitorar a interação com emails, otimizando a comunicação e evitando envios desnecessários."}],["$","h6",null,{"className":"text-lg pb-2 pt-4","style":{"fontWeight":"600"},"children":"7. Divulgação de dados a terceiros"}],["$","p",null,{"className":"text-sm pt-2 text-justify","children":"A base de dados de informações coletadas pela Stixmed poderá ser disponibilizada a parceiros estratégicos com o objetivo de promover benefícios e gerar resultados mútuos, como aprimoramento de produtos, serviços e estratégias de publicidade. Essa base de dados também poderá ser compartilhada para fins de marketing com parceiros comerciais, cuja lista completa está disponível em: (https://stixmed.med.br/parceiros/), visando a oferta de serviços ou produtos em condições mais vantajosas para você."}],["$","p",null,{"className":"text-sm pt-2 text-justify","children":"Pode ser necessário que o Stixmed divulgue seus dados pessoais em conformidade com exigências legais, processos judiciais, litígios e/ou solicitações de autoridades públicas e governamentais, tanto no território nacional quanto no exterior. Além disso, poderemos compartilhar informações sobre você caso seja determinado que a divulgação é necessária ou apropriada para fins de segurança nacional, cumprimento da lei ou outros assuntos de relevante interesse público."}],["$","p",null,{"className":"text-sm pt-2 text-justify","children":"Podemos também divulgar informações a seu respeito caso seja determinado que tal divulgação é razoavelmente necessária para garantir o cumprimento de nossos termos e condições ou para proteger nossas operações e usuários. Ademais, em caso de reorganização, fusão ou venda da empresa, poderemos transferir todas as informações pessoais coletadas para os terceiros envolvidos no processo."}],["$","h6",null,{"className":"text-lg pb-2 pt-4","style":{"fontWeight":"600"},"children":"8. Proteção de seus dados pessoais"}],["$","p",null,{"className":"text-sm pt-2 text-justify","children":"O Stixmed trata a segurança dos seus dados pessoais com o mais alto nível de seriedade. Para garantir essa proteção, comunicamos nossas diretrizes de privacidade e segurança a todos os colaboradores e implementamos rigorosamente as salvaguardas de privacidade em nossas operações. Durante a transmissão, os serviços on-line utilizam criptografia para proteger suas informações pessoais. Quando armazenados, esses dados são mantidos em sistemas computacionais com acesso restrito, localizados em instalações dotadas de medidas físicas de segurança. Além disso, os dados são armazenados de forma criptografada, inclusive quando utilizamos serviços de armazenamento de terceiros, assegurando sua proteção em todas as etapas."}],["$","p",null,{"className":"text-sm pt-2 text-justify","children":"O Stixmed adota rigorosas medidas de segurança para proteger seus dados pessoais. Contudo, considerando que nenhum sistema de segurança é absolutamente infalível, o Stixmed se exime de quaisquer responsabilidades por eventuais danos ou prejuízos decorrentes de falhas, vírus ou invasões ao banco de dados de seus produtos, serviços e site, salvo nos casos em que tenha agido com dolo ou culpa. Em situações em que informações contendo dados pessoais forem comprometidas, o Stixmed compromete-se a dar a devida publicidade ao ocorrido."}],["$","p",null,{"className":"text-sm pt-2 text-justify","children":"Adicionalmente, ao utilizar fóruns de mensagens ou serviços de redes sociais vinculados ao Stixmed, as informações pessoais compartilhadas por você se tornarão visíveis a outros usuários, podendo ser lidas, coletadas ou utilizadas por eles. Ressaltamos que você é integralmente responsável pelas informações que optar por compartilhar nessas plataformas. Por exemplo, ao comentar em uma postagem no Facebook, as informações fornecidas serão públicas e acessíveis a outros usuários."}],["$","p",null,{"className":"text-sm pt-2 text-justify","children":"Cada paciente possui um código identificador único, pessoal e intransferível. Nossos sistemas utilizam esses códigos exclusivamente para leitura, preservando o conteúdo dos dados pessoais e garantindo o anonimato das informações."}],["$","p",null,{"className":"text-sm pt-2 text-justify","children":"No caso de resultados e laudos de exames, os especialistas, durante sua elaboração, têm acesso exclusivamente ao nome e ao número de identificação do paciente, assegurando, dessa forma, a proteção de sua privacidade."}],["$","h6",null,{"className":"text-lg pb-2 pt-4","style":{"fontWeight":"600"},"children":"9. Integridade e acesso a dados pessoais"}],["$","p",null,{"className":"text-sm pt-2 text-justify","children":"O Stixmed proporciona mecanismos para que você mantenha suas informações pessoais precisas, completas e atualizadas com facilidade. As informações pessoais serão retidas pelo período necessário para atender às finalidades estabelecidas nesta Política de Privacidade, salvo se um período de retenção mais longo for exigido ou permitido pela legislação aplicável."}],["$","p",null,{"className":"text-sm pt-2 text-justify","children":"Você pode colaborar para garantir que suas informações e preferências de contato estejam corretas, completas e atualizadas. Em relação a outras informações pessoais armazenadas, oferecemos acesso para fins diversos, incluindo solicitação de atualização, correção ou exclusão dos dados, desde que o Stixmed não seja legalmente obrigado ou não tenha justificativa legítima para retê-los. Reservamo-nos o direito de recusar o processamento de solicitações que sejam infundadas, vexatórias, que prejudiquem a privacidade de terceiros, que sejam extremamente impraticáveis ou cujo acesso não seja exigido por lei."}],["$","p",null,{"className":"text-sm pt-2 text-justify","children":"Em casos em que o paciente exclui sua conta, seus dados pessoais e não pessoais serão mantidos nos nossos bancos de dados e seguem a mesma questão de sigilo previstas nestes termos."}],["$","h6",null,{"className":"text-lg pb-2 pt-4","style":{"fontWeight":"600"},"children":"10. Quem é o nosso Encarregado de Dados?"}],["$","p",null,{"className":"text-sm pt-2 text-justify","children":"O Encarregado (DPO – Data Protection Officer) é pessoa indicada pelo Controlador para atuar como canal de comunicação entre este, os Titulares dos dados e a Autoridade Nacional de Proteção de Dados (ANPD), papel exercido por:"}],["$","p",null,{"className":"text-sm pt-3 pb-3 text-justify","children":["Email: ",["$","a",null,{"style":{"color":"black","fontSize":"14px"},"href":"malito:privacidade@stixmed.med.br","children":"privacidade@stixmed.med.br"}]]}]]}]],[["$","link","0",{"rel":"stylesheet","href":"/_next/static/css/ecf5c86cb3aafc44.css","precedence":"next","crossOrigin":"$undefined","nonce":"$undefined"}]],["$","$La",null,{"children":"$Lb"}]]}],{},null,false]},null,false]},null,false],["$","$1","h",{"children":[null,["$","$1","BBMMTGNPuD9rYDMVNxlP4",{"children":[["$","$Lc",null,{"children":"$Ld"}],["$","$Le",null,{"children":"$Lf"}],null]}]]}],false]],"m":"$undefined","G":["$10","$undefined"],"s":false,"S":true}
